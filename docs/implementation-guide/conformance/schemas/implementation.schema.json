{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Implementation conformance metadata",
  "type": "object",
  "required": [
    "name",
    "version",
    "conformance_level",
    "source_revision"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "source_revision": {
      "type": "string",
      "minLength": 1
    },
    "conformance_level": {
      "enum": [
        "CL-1",
        "CL-2",
        "CL-3",
        "CL-4"
      ]
    },
    "profiles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "known_limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
