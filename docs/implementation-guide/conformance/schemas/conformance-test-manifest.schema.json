{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Conformance test manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "specificationRevision",
    "profile",
    "implementation",
    "tests"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "specificationRevision": {
      "type": "string",
      "minLength": 1
    },
    "profile": {
      "enum": [
        "CL-1",
        "CL-2",
        "CL-3",
        "CL-4"
      ]
    },
    "implementation": {
      "type": "object",
      "required": [
        "name",
        "version",
        "adapter"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "adapter": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "tests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "test_id",
          "operation",
          "expected_status",
          "request"
        ],
        "properties": {
          "test_id": {
            "type": "string",
            "pattern": "^CT-"
          },
          "operation": {
            "type": "string"
          },
          "required_capability": {
            "type": "string"
          },
          "expected_status": {
            "enum": [
              "accepted",
              "rejected"
            ]
          },
          "expected_reason": {
            "type": "string"
          },
          "request": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
