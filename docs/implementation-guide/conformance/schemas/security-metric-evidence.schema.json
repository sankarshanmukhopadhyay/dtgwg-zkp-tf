{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Security metric evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "metric_id",
    "period_start",
    "period_end",
    "value",
    "unit",
    "owner",
    "threshold",
    "status",
    "privacy_boundary",
    "retention_days",
    "linked_threats",
    "linked_guardrails",
    "evidence_references"
  ],
  "properties": {
    "metric_id": {
      "pattern": "^ZM-[0-9]{2}$"
    },
    "period_start": {
      "type": "string",
      "format": "date-time"
    },
    "period_end": {
      "type": "string",
      "format": "date-time"
    },
    "value": {
      "type": "number"
    },
    "unit": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "threshold": {
      "type": "string"
    },
    "status": {
      "enum": [
        "normal",
        "watch",
        "breach"
      ]
    },
    "privacy_boundary": {
      "type": "string",
      "minLength": 10
    },
    "retention_days": {
      "type": "integer",
      "minimum": 0
    },
    "linked_threats": {
      "type": "array",
      "items": {
        "pattern": "^THR-[0-9]{3}$"
      }
    },
    "linked_guardrails": {
      "type": "array",
      "items": {
        "pattern": "^ZGR-[0-9]{2}$"
      }
    },
    "evidence_references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
